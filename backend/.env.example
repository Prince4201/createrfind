# Server
PORT=8080
NODE_ENV=production

# Google Cloud Project
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Firebase (for local development — in production, use Secret Manager)
FIREBASE_PROJECT_ID=your-firebase-project-id

# YouTube Data API v3 (for local development)
YOUTUBE_API_KEY=your-youtube-api-key

# SendGrid (for local development)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=YouTube Creator Discovery

# Google Sheets
GOOGLE_SHEET_ID=your-google-sheet-id

# Frontend URLs (comma-separated list of allowed CORS origins)
# Example: https://myapp.vercel.app,http://localhost:3000
FRONTEND_URL=http://localhost:3000,http://localhost:3001

# Secret Manager secret names (production)
SECRET_YOUTUBE_API_KEY=youtube-api-key
SECRET_SENDGRID_API_KEY=sendgrid-api-key
SECRET_SHEETS_CREDENTIALS=sheets-service-account
